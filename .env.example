# Base de datos (PostgreSQL - Supabase/Neon/Render)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Contraseña del panel de administración (texto plano o hash bcrypt)
ADMIN_PASSWORD="admin_password_segura"

# Contraseña para autorizar dispositivos escáner (debe ser distinta a ADMIN_PASSWORD)
SCANNER_PASSWORD="clave_para_autorizar_telefonos_scanner"

# Secreto de 32+ caracteres para cifrar cookies de sesión (iron-session)
SESSION_SECRET="una_clave_secreta_muy_larga_y_segura_para_las_cookies_32_chars"

# URL base de la app (sin / al final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Opcional: Supabase (solo si usas Supabase como hosting de Postgres)
# SUPABASE_URL=https://project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=...
# SUPABASE_SECRET_KEY=...
# SUPABASE_JWKS_URL=...
