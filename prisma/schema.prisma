generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Socio {
  id             Int           @id @default(autoincrement())
  numeroSocio    String        @unique
  nombre         String
  credito        Float         @default(0)
  estadoPulsera  String        @default("activa")
  qrToken        String        @unique @default(uuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transacciones  Transaccion[]
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Float
  imagen    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Heartbeat {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  timestamp DateTime @default(now())
}

model Transaccion {
  id          Int      @id @default(autoincrement())
  socioId     Int
  socio       Socio    @relation(fields: [socioId], references: [id])
  tipo        String
  cantidad    Float
  descripcion String?
  createdAt   DateTime @default(now())
}
