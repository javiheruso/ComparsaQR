generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TipoVinculacion {
  socio
  hijos_mayores
  socios_menores
  hijo_socio
}

enum EstadoPulsera {
  activa
  inactiva
  perdida
}

enum TipoTransaccion {
  carga
  consumo
}

model Socio {
  id               Int              @id @default(autoincrement())
  numeroSocio      String           @unique
  dni              String?          @unique
  nombre           String
  apellido1        String?
  apellido2        String?
  tipoVinculacion  TipoVinculacion  @default(socio)
  fechaNacimiento  DateTime?
  credito          Float            @default(0)
  estadoPulsera    EstadoPulsera    @default(activa)
  qrToken          String           @unique @default(uuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  transacciones    Transaccion[]
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Float
  imagen    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Heartbeat {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  timestamp DateTime @default(now())
}

model Transaccion {
  id          Int              @id @default(autoincrement())
  socioId     Int
  socio       Socio            @relation(fields: [socioId], references: [id], onDelete: Cascade)
  tipo        TipoTransaccion
  cantidad    Float
  descripcion String?
  operador    String?
  createdAt   DateTime         @default(now())
}
